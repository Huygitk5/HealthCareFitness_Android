<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="ring" android:thickness="6dp" android:useLevel="false">
            <solid android:color="#40FFFFFF" /> </shape>
    </item>
    <item>
        <rotate android:fromDegrees="270" android:toDegrees="270">
            <shape android:shape="ring" android:thickness="6dp" android:useLevel="true">
                <gradient android:startColor="#4DAA9A" android:endColor="#6DF5E1" android:angle="0" />
            </shape>
        </rotate>
    </item>
</layer-list>