<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8F8">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottomNav">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_arrow_back_breakfast"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/tvBreakfastTitle"
                app:layout_constraintBottom_toBottomOf="@id/tvBreakfastTitle"/>

            <TextView
                android:id="@+id/tvBreakfastTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Breakfast"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="#000"
                app:layout_constraintStart_toEndOf="@+id/ivBack"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_marginStart="16dp"/>

            <!-- Meat Section -->
            <TextView
                android:id="@+id/tvMeatLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Meat"
                android:textColor="@android:color/white"
                android:background="@drawable/rounded_corner_red_breakfast"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvBreakfastTitle" />

            <TableLayout
                android:id="@+id/tlMeat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:stretchColumns="0"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@+id/tvMeatLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TableRow android:background="#BDBDBD">
                    <TextView android:text="Name" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                    <TextView android:text="Img" android:gravity="center" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                    <TextView android:text="Cal" android:gravity="center" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                    <TextView android:text="Carb" android:gravity="center" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                    <TextView android:text="Pro" android:gravity="center" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                    <TextView android:text="Fat" android:gravity="center" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                </TableRow>

                <TableRow android:background="#FFFFFF" android:layout_marginTop="1dp" android:gravity="center_vertical">
                    <TextView android:text="Pork" android:padding="8dp" android:textColor="#000"/>
                    <ImageView android:src="@drawable/ic_placeholder_nutrition" style="@style/FoodImageSmall" android:layout_gravity="center"/>
                    <TextView android:text="100" android:gravity="center" android:padding="8dp"/>
                    <TextView android:text="10" android:gravity="center" android:padding="8dp"/>
                    <TextView android:text="20" android:gravity="center" android:padding="8dp"/>
                    <TextView android:text="15" android:gravity="center" android:padding="8dp"/>
                </TableRow>

                <TableRow android:background="#FFFFFF" android:layout_marginTop="1dp" android:gravity="center_vertical">
                    <TextView android:text="Beef" android:padding="8dp" android:textColor="#000"/>
                    <ImageView android:src="@drawable/ic_placeholder_nutrition" style="@style/FoodImageSmall" android:layout_gravity="center"/>
                    <TextView android:text="120" android:gravity="center" android:padding="8dp"/>
                    <TextView android:text="0" android:gravity="center" android:padding="8dp"/>
                    <TextView android:text="25" android:gravity="center" android:padding="8dp"/>
                    <TextView android:text="12" android:gravity="center" android:padding="8dp"/>
                </TableRow>
            </TableLayout>

            <!-- Vegetable Section -->
            <TextView
                android:id="@+id/tvVegetableLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Vegetable"
                android:textColor="@android:color/white"
                android:background="@drawable/rounded_corner_lightgreen_breakfast"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tlMeat" />

            <TableLayout
                android:id="@+id/tlVegetable"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:stretchColumns="0"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@+id/tvVegetableLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TableRow android:background="#BDBDBD">
                    <TextView android:text="Name" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                    <TextView android:text="Img" android:gravity="center" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                    <TextView android:text="Cal" android:gravity="center" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                    <TextView android:text="Carb" android:gravity="center" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                    <TextView android:text="Pro" android:gravity="center" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                    <TextView android:text="Fat" android:gravity="center" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                </TableRow>

                <TableRow android:background="#FFFFFF" android:layout_marginTop="1dp" android:gravity="center_vertical">
                    <TextView android:text="Potato" android:padding="8dp" android:textColor="#000"/>
                    <ImageView android:src="@drawable/ic_placeholder_nutrition" style="@style/FoodImageSmall" android:layout_gravity="center"/>
                    <TextView android:text="70" android:gravity="center" android:padding="8dp"/>
                    <TextView android:text="15" android:gravity="center" android:padding="8dp"/>
                    <TextView android:text="2" android:gravity="center" android:padding="8dp"/>
                    <TextView android:text="0.1" android:gravity="center" android:padding="8dp"/>
                </TableRow>

                <TableRow android:background="#FFFFFF" android:layout_marginTop="1dp" android:gravity="center_vertical">
                    <TextView android:text="Corn" android:padding="8dp" android:textColor="#000"/>
                    <ImageView android:src="@drawable/ic_placeholder_nutrition" style="@style/FoodImageSmall" android:layout_gravity="center"/>
                    <TextView android:text="90" android:gravity="center" android:padding="8dp"/>
                    <TextView android:text="20" android:gravity="center" android:padding="8dp"/>
                    <TextView android:text="3" android:gravity="center" android:padding="8dp"/>
                    <TextView android:text="1" android:gravity="center" android:padding="8dp"/>
                </TableRow>
            </TableLayout>

            <!-- Fruit Section -->
            <TextView
                android:id="@+id/tvFruitLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Fruit"
                android:textColor="@android:color/white"
                android:background="@drawable/rounded_corner_blue_breakfast"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tlVegetable" />

            <TableLayout
                android:id="@+id/tlFruit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:stretchColumns="0"
                android:background="#E0E0E0"
                app:layout_constraintTop_toBottomOf="@+id/tvFruitLabel"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TableRow android:background="#BDBDBD">
                    <TextView android:text="Name" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                    <TextView android:text="Img" android:gravity="center" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                    <TextView android:text="Cal" android:gravity="center" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                    <TextView android:text="Carb" android:gravity="center" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                    <TextView android:text="Pro" android:gravity="center" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                    <TextView android:text="Fat" android:gravity="center" android:padding="8dp" android:textStyle="bold" android:textColor="#000"/>
                </TableRow>

                <TableRow android:background="#FFFFFF" android:layout_marginTop="1dp" android:gravity="center_vertical">
                    <TextView android:text="Banana" android:padding="8dp" android:textColor="#000"/>
                    <ImageView android:src="@drawable/ic_placeholder_nutrition" style="@style/FoodImageSmall" android:layout_gravity="center"/>
                    <TextView android:text="105" android:gravity="center" android:padding="8dp"/>
                    <TextView android:text="27" android:gravity="center" android:padding="8dp"/>
                    <TextView android:text="1.3" android:gravity="center" android:padding="8dp"/>
                    <TextView android:text="0.3" android:gravity="center" android:padding="8dp"/>
                </TableRow>
            </TableLayout>

            <!-- Warning Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvWarning"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFF9C4"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/tlFruit"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:text="▲: Tránh các sản phẩm: Đậu nành, Nước có gas, Mè trắng, Bắp cải"
                    android:textColor="#000"
                    android:textSize="13sp"/>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_bottom_nav_container"
        android:elevation="8dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:weightSum="5">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_home"
                app:tint="#009688" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_nutrition"
            android:layout_width="wrap_content"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:background="@drawable/bg_nav_active"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_nutriton"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Nutrition"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_workout"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_workout"
                app:tint="#009688" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_trainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_trainer"
                app:tint="#009688" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_profile"
                app:tint="#009688" />
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
