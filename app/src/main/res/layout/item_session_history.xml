<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:orientation="horizontal"
    android:paddingVertical="8dp"
    android:paddingHorizontal="4dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/ivPlanThumb"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_circle_primary" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvSessionName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tên buổi tập"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:singleLine="true"
            android:ellipsize="end"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_workout"
                app:tint="#2196F3"/>

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0s"
                android:textSize="12sp"
                android:textColor="#2196F3"
                android:layout_marginStart="2dp"/>

            <Space
                android:layout_width="8dp"
                android:layout_height="wrap_content"/>

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_nutriton"
                app:tint="#FF7043"/>

            <TextView
                android:id="@+id/tvKcal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0 Kcal"
                android:textSize="12sp"
                android:textColor="#FF7043"
                android:layout_marginStart="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tvSessionDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DD thg M, H:MM CH"
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        android:layout_marginStart="8dp"
        android:gravity="end|center_vertical"/>

</LinearLayout>
