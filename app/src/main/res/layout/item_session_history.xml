<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="10dp"
    android:paddingHorizontal="2dp">

    <!-- Thumbnail bo tròn -->
    <ImageView
        android:id="@+id/ivSessionThumb"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:scaleType="centerCrop"
        android:src="@drawable/workout_1" />

    <!-- Tên + stats -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginHorizontal="12dp">

        <TextView
            android:id="@+id/tvSessionName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#1A1A1A"
            android:textSize="14sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="Ngày 1: Gym (Full Body)" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <ImageView
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:src="@drawable/ic_timer"
                app:tint="#1D9E75" />

            <TextView
                android:id="@+id/tvSessionDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="10dp"
                android:textColor="#1D9E75"
                android:textSize="12sp"
                android:text="41m 48s" />

            <ImageView
                android:layout_width="13dp"
                android:layout_height="13dp"
                android:src="@drawable/ic_fire"
                app:tint="#D85A30" />

            <TextView
                android:id="@+id/tvSessionKcal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:textColor="#D85A30"
                android:textSize="12sp"
                android:text="292.6 Kcal" />

        </LinearLayout>
    </LinearLayout>

    <!-- Ngày giờ (trailing) -->
    <TextView
        android:id="@+id/tvSessionDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end|center_vertical"
        android:textColor="#9E9E9E"
        android:textSize="11sp"
        android:lineSpacingExtra="2dp"
        android:text="25 thg 3\n6:52 CH" />

</LinearLayout>
