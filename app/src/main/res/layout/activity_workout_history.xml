<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F4F7F6"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View android:id="@+id/headerBg"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#4DAA9A" />

    <ImageButton android:id="@+id/btnBack"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_alignTop="@id/headerBg"
        android:layout_alignBottom="@id/headerBg"
        android:layout_marginStart="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_back"
        app:tint="#FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignTop="@id/headerBg"
        android:layout_alignBottom="@id/headerBg"
        android:gravity="center"
        android:text="Lịch sử"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <androidx.core.widget.NestedScrollView
        android:layout_below="@id/headerBg"
        android:layout_marginTop="-20dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/btnDone"
        android:scrollbars="none">

        <LinearLayout
            android:orientation="vertical"
            android:background="@drawable/bg_top_rounded_white"
            android:paddingTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardCalendar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="40dp">

                        <ImageButton
                            android:id="@+id/btnPrevMonth"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_circle_gray_light"
                            android:src="@drawable/ic_back"
                            app:tint="#4DAA9A" />

                        <TextView
                            android:id="@+id/tvMonthYear"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="thg 3 2026"
                            android:textColor="#1A1A1A"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <ImageButton
                            android:id="@+id/btnNextMonth"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_circle_gray_light"
                            android:src="@drawable/ic_next"
                            app:tint="#4DAA9A" />

                    </LinearLayout>

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:columnCount="7"
                        android:layout_marginTop="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_columnWeight="1" android:text="CN" android:gravity="center" android:textSize="12sp" android:textColor="#9E9E9E"/>
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_columnWeight="1" android:text="T2" android:gravity="center" android:textSize="12sp" android:textColor="#9E9E9E"/>
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_columnWeight="1" android:text="T3" android:gravity="center" android:textSize="12sp" android:textColor="#9E9E9E"/>
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_columnWeight="1" android:text="T4" android:gravity="center" android:textSize="12sp" android:textColor="#9E9E9E"/>
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_columnWeight="1" android:text="T5" android:gravity="center" android:textSize="12sp" android:textColor="#9E9E9E"/>
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_columnWeight="1" android:text="T6" android:gravity="center" android:textSize="12sp" android:textColor="#9E9E9E"/>
                        <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_columnWeight="1" android:text="T7" android:gravity="center" android:textSize="12sp" android:textColor="#9E9E9E"/>
                    </GridLayout>

                    <GridLayout
                        android:id="@+id/gridCalendar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="7"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginBottom="10dp"
                android:text="Báo cáo hàng tuần"
                android:textColor="#1A1A1A"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardWeekly"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:orientation="vertical"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">

                            <TextView
                                android:id="@+id/tvWeekRange"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="22 thg 3 – 28 thg 3"
                                android:textColor="#1A1A1A"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvWeekSessionCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="1 Lần tập"
                                android:textColor="#9E9E9E"
                                android:textSize="13sp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_pill_green_light"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="5dp"
                            android:text="Tuần này"
                            android:textColor="#0F6E56"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#F0F0F0" />

                    <LinearLayout
                        android:orientation="horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="20dp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_timer"
                                app:tint="#1D9E75" />

                            <TextView
                                android:id="@+id/tvTotalTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="5dp"
                                android:text="41m 48s"
                                android:textColor="#1D9E75"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_fire"
                                app:tint="#D85A30" />

                            <TextView
                                android:id="@+id/tvTotalKcal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="5dp"
                                android:text="292.6 Kcal"
                                android:textColor="#D85A30"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvSessions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/tvWeekEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:text="Tuần này chưa tập luyện"
                        android:textColor="#BDBDBD"
                        android:textSize="13sp"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_history"
                    app:tint="#BDBDBD" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="Chưa có lịch sử tập luyện\nHãy hoàn thành buổi tập đầu tiên!"
                    android:textColor="#BDBDBD"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDone"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="28dp"
        android:layout_marginTop="12dp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="XONG"
        android:textSize="15sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        android:textColor="#FFFFFF"
        app:backgroundTint="#4DAA9A"
        app:cornerRadius="28dp" />

</RelativeLayout>
