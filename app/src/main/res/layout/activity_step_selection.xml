<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/stepProgressBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:indicatorColor="#589A8D"
        app:trackColor="#E0E0E0"
        app:trackThickness="4dp"
        app:layout_constraintTop_toTopOf="parent"
        tools:progress="33" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_arrow_back_breakfast"
        app:tint="#333333"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stepProgressBar" />

    <!-- Thay thế đoạn TextView id/tvStepCount bằng đoạn này -->
    <LinearLayout
        android:id="@+id/stepIndicatorContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- BƯỚC 1 -->
        <TextView
            android:id="@+id/tvStep1Circle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/step_circle_selected"
            android:gravity="center"
            android:text="1"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvStep1Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Dụng cụ"
            android:textColor="#589A8D"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Đường kẻ nối -->
        <View
            android:layout_width="20dp"
            android:layout_height="2dp"
            android:layout_marginHorizontal="4dp"
            android:background="#E0E0E0" />

        <!-- BƯỚC 2 -->
        <TextView
            android:id="@+id/tvStep2Circle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/step_circle_unselected"
            android:gravity="center"
            android:text="2"
            android:textColor="#666666"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvStep2Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Nhóm cơ"
            android:textColor="#9E9E9E"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <View
            android:layout_width="20dp"
            android:layout_height="2dp"
            android:layout_marginHorizontal="4dp"
            android:background="#E0E0E0" />

        <!-- BƯỚC 3 -->
        <TextView
            android:id="@+id/tvStep3Circle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/step_circle_unselected"
            android:gravity="center"
            android:text="3"
            android:textColor="#666666"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvStep3Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="Bài tập"
            android:textColor="#9E9E9E"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>
    <TextView
        android:id="@+id/tvStepTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="16dp"
        tools:text="Tiêu đề Bước"
        android:textColor="#333333"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btnBack" />

    <ProgressBar
        android:id="@+id/progressBarApi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:indeterminateTint="#589A8D"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSelection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingBottom="100dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvStepTitle" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnNextStep"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_premium_btn"
        android:text="TIẾP TỤC"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:elevation="8dp"
        android:stateListAnimator="@null"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>